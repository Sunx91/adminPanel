PORT=3000

# Postgres: use either DATABASE_URL (Supabase) OR the variables below
# DATABASE_URL=postgresql://...

DB_NAME=ecommerce_admin
DB_USER=postgres
DB_PASS=yourpassword
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false

JWT_SECRET=your_long_random_string_at_least_32_chars
COOKIE_SECRET=another_long_random_string_different_from_jwt
JWT_EXPIRES_IN=8h

# First run: set DB_SYNC=true once to create tables, then false
DB_SYNC=false
