PORT=3000
NODE_ENV=development

# --- Database: Supabase (recommended) ---
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- Database: local (comment out DATABASE_URL) ---
DB_NAME=ecommerce_admin
DB_USER=postgres
DB_PASS=yourpassword
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false

# Connection pool (optional; defaults are fine for small apps)
# DB_POOL_MAX=10
# DB_POOL_MIN=0

JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
COOKIE_SECRET=another_long_random_secret_at_least_32_chars_different_from_jwt
# JWT lifetime for /api/login (e.g. 8h, 7d, 900)
JWT_EXPIRES_IN=8h

# Development only: create/alter tables on startup (never enable in production without override)
DB_SYNC=false
# ALLOW_DB_SYNC_IN_PRODUCTION=true

# --- Production / reverse proxy ---
# TRUST_PROXY=true
# SESSION_COOKIE_SECURE=true
# SESSION_MAX_AGE_MS=28800000
# API_LOGIN_MAX_ATTEMPTS=30

# Dangerous: wipes DB. Blocked in production unless:
# ALLOW_SEED_IN_PRODUCTION=true
